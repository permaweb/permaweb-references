{
  "name": "@permaweb/references",
  "version": "0.1.2",
  "description": "reference@1.0 js client: name resolution and management on the Permaweb",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run --no-cache",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "arweave": "*",
    "arbundles": "*"
  },
  "peerDependenciesMeta": {
    "arweave": {
      "optional": true
    },
    "arbundles": {
      "optional": true
    }
  }
}
